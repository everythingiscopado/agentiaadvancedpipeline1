                var nextTime;
                timers.forEach(function (timer) {
                    nextTime = +timer.getAttribute('data-start-seconds') + 1;
                    timer.setAttribute('data-start-seconds', nextTime);
                    timer.innerHTML = formatTime(nextTime);
                });
                
