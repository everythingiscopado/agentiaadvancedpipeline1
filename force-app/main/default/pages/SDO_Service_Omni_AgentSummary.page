                            user.status = getStatus();
                            user.gender = getGender();
                            user.channels = getChannels();
                            user.queues = getQueues(user.channels);
                            user.defaultTimes = getDefaultTimes();
                            user.load = getLoad();
                            user.items = user.load;
                            
                            users.push(user);
                            if (idx === records.length - 1 && callback) {
